```python
import numpy as np
import torch

MAPPED_DIM = 40
DESCRIPTION = "Mobility, reachable space, quadrants, adjacency, turn, total moves"

def mapping(board_tensor: torch.Tensor) -> torch.Tensor:
    bb = board_tensor.cpu().numpy()
    black = bb[:64].astype(bool)
    white = bb[64:128].astype(bool)
    impassable = bb[128:192].astype(bool)
    turn = bb[192]
    
    # Helper to get indices
    black_sq = np.where(black)[0]
    white_sq = np.where(white)[0]
    
    # Total moves
    total_moves = np.sum(impassable)
    
    # Directions
    dirs = [-8, 8, -1, 1, -9, -7, 7, 9]
    
    def count_mobility(pieces, occ, imp):
        mob = 0
        for p in pieces:
            r, c = divmod(p, 8)
            for d in dirs:
                nr, nc = r + (d // 8), c + (d % 8)
                while 0 <= nr < 8 and 0 <= nc < 8:
                    sq = nr * 8 + nc
                    if occ[sq] or imp[sq]:
                        break
                    mob += 1
                    nr += (d // 8)
                    nc += (d % 8)
        return mob

    def flood_fill(pieces, occ, imp):
        free = ~occ & ~imp
        reachable = np.zeros(64, dtype=bool)
        for p in pieces:
            if free[p]:
                reachable[p] = True
        changed = True
        while changed:
            changed = False
            for p in np.where(reachable)[0]:
                r, c = divmod(p, 8)
                for d in dirs:
                    nr, nc = r + (d // 8), c + (d % 8)
                    while 0 <= nr < 8 and 0 <= nc < 8:
                        sq = nr * 8 + nc
                        if free[sq] and not reachable[sq]:
                            reachable[sq] = True
                            changed = True
                        if occ[sq] or imp[sq]:
                            break
                        nr += (d // 8)
                        nc += (d % 8)
        return np.sum(reachable)

    # Mobility
    b_mob = count_mobility(black_sq, white, impassable)
    w_mob = count_mobility(white_sq, black, impassable)
    
    # Reachable space
    b_space = flood_fill(black_sq, white, impassable)
    w_space = flood_fill(white_sq, black, impassable)
    
    # Center 4x4 (rows 2-5, cols 2-5) -> indices 18..45
    center_mask = np.zeros(64, dtype=bool)
    for r in range(2, 6):
        for c in range(2, 6):
            center_mask[r*8+c] = True
    free_center = center_mask & ~black & ~white & ~impassable
    b_center_space = np.sum(center_mask & flood_fill_mask(black_sq, white, impassable)) # Wait, flood_fill returns count, not mask. Let's adjust.
```

