import torch
import numpy as np

MAPPED_DIM = 64
DESCRIPTION = "Mobility, space control, piece positions, and connectivity features"

def mapping(board_tensor: torch.Tensor) -> torch.Tensor:
    bb_black = board_tensor[0:64].bool()
    bb_white = board_tensor[64:128].bool()
