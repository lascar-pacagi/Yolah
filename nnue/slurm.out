Let's verify the symmetry check.
Symmetry under 180 rotation and color swap:
Rotate 180: bit i -> bit 63-i.
Swap colors: Black becomes White, White becomes Black.
So check if `black_bb == rotate180(white_bb)` and `white_bb == rotate180(black_bb)`.
If both true, sym=1, else 0.
This is a strong signal for balanced positions.

Implementation details:
Bitboard rotation 180: `rot = ((bb & 0xFF) << 56) | ((bb & 0xFF00) << 40) | ...`
Or simpler: `rot = sum(((bb >> i) & 1) << (63-i) for i in range(64))`
In Python, this is fine.

Calculating 1-ply mobility:
For each piece at square `p`:
  Directions: 8 vectors.
  For each direction `d`:
    `sq = p + d`
    While `sq` in bounds and `sq` not in `black_bb` and `sq` not in `white_bb` and `sq` not in `impassable_bb`:
      Add `sq` to mobility set.
      `sq += d`
This is straightforward.

Let's code this in Python.
We need to handle the tensor input.
Convert to bitboards.
Compute features.
Normalize to [0, 1].
Return tensor.

One thing: The input tensor is float32. We can cast to int.
`bb = int(torch.dot(tensor, torch.tensor([2.0**i for i in range(193)])))`
But `2.0**i` might lose precision for large i.
Better: `bb = sum(int(tensor[i]) * (1 << i) for i in range(193))`
This is safe.

Let's write the code structure.

```python
import torch
import numpy as np

MAPPED_DIM = 32
DESCRIPTION = "Exclusive/contested mobility, trapped, symmetry, wall-adj, center/corner/edge control"

def mapping(board_tensor: torch.Tensor) -> torch.Tensor:
    # Extract bitboards
    bb = int(torch.dot(board_tensor, torch.tensor([2.0**i for i in range(193)], dtype=torch.float64)).item())
    # Actually, 2.0**63 is fine in float64.
    # Or use integer arithmetic directly from tensor elements
    bb = 0
    for i in range(193):
        if board_tensor[i].item() > 0.5:
            bb |= (1 << i)
            
    black_bb = bb & 0xFFFFFFFFFFFFFFFF
    white_bb = (bb >> 64) & 0xFFFFFFFFFFFFFFFF
    impassable_bb = (bb >> 128) & 0xFFFFFFFFFFFFFFFF
    turn = 1 if (bb >> 192) & 1 else 0
    
    # Directions for sliding
    dirs = [1, 8, -1, -8, 7, -7, 9, -9] # E, S, W, N, SE, NW, NE, SW
    # Note: row-major, so +1 is East, +8 is South, -1 is West, -8 is North.
    # Diagonals: +7 (SE), -7 (NW), +9 (NE), -9 (SW).
    # Check boundaries carefully.
    
    def get_mobility(pieces_bb):
        mob = 0
        pieces = []
        tmp = pieces_bb
        while tmp:
            p = (tmp & -tmp).bit_length() - 1
            pieces.append(p)
            tmp &= tmp - 1
            
        for p in pieces:
            row, col = divmod(p, 8)
            for d in dirs:
                sq = p
                while True:
                    sq += d
                    r, c = divmod(sq, 8)
                    if r < 0 or r > 7 or c < 0 or c > 7:
                        break
                    if (impassable_bb >> sq) & 1:
                        break
                    if (black_bb >> sq) & 1 or (white_bb >> sq) & 1:
                        break
                    mob |= (1 << sq)
        return mob

    black_mob = get_mobility(black_bb)
    white_mob = get_mobility(white_bb)
    
    excl_b = black_mob & ~white_mob
    excl_w = white_mob & ~black_mob
    contested = black_mob & white_mob
    
    mob_b = bin(black_mob).count('1')
    mob_w = bin(white_mob).count('1')
    excl_b_cnt = bin(excl_b).count('1')
    excl_w_cnt = bin(excl_w).count('1')
    contested_cnt = bin(contested).count('1')
    
    # Trapped pieces
    trapped_b = 0
    for p in range(64):
        if (black_bb >> p) & 1:
            # Check if any move possible
            has_move = False
            row, col = divmod(p, 8)
            for d in dirs:
                sq = p + d
                r, c = divmod(sq, 8)
                if 0 <= r <= 7 and 0 <= c <= 7:
                    if not ((impassable_bb >> sq) & 1) and not ((black_bb >> sq) & 1) and not ((white_bb >> sq) & 1):
                        has_move = True
                        break
            if not has_move:
                trapped_b += 1
                
    trapped_w = 0
    for p in range(64):
        if (white_bb >> p) & 1:
            has_move = False
            row, col = divmod(p, 8)
            for d in dirs:
                sq = p + d
                r, c = divmod(sq, 8)
                if 0 <= r <= 7 and 0 <= c <= 7:
                    if not ((impassable_bb >> sq) & 1) and not ((black_bb >> sq) & 1) and not ((white_bb >> sq) & 1):
                        has_move = True
                        break
            if not has_move:
                trapped_w += 1
                
    # Fill level
    fill = bin(impassable_bb).count('1') / 64.0
    
    # Symmetry
    def rot180(bb):
        res = 0
        for i in range(64):
            if (bb >> i) & 1:
                res |= (1 << (63 - i))
        return res
        
    sym = 1.0 if (black_bb == rot180(white_bb) and white_bb == rot180(black_bb)) else 0.0
    
    # Center, Corner, Edge
    center_mask = 0
    for r in range(2, 6):
        for c in range(2, 6):
            center_mask |= (1 << (r * 8 + c))
    corner_mask = 1 | (1 << 7) | (1 << 56) | (1 << 63)
    edge_mask = 0
    for r in range(8):
        for c in range(8):
            if c == 0 or c == 7 or r == 0 or r == 7:
                edge_mask |= (1 << (r * 8 + c))
    edge_mask &= ~corner_mask # Exclude corners from edges
    
    center_b = bin(black_bb & center_mask).count('1') / 4.0
    center_w = bin(white_bb & center_mask).count('1') / 4.0
    corner_b = bin(black_bb & corner_mask).count('1') / 4.0
    corner_w = bin(white_bb & corner_mask).count('1') / 4.0
    edge_b = bin(black_bb & edge_mask).count('1') / 4.0
    edge_w = bin(white_bb & edge_mask).count('1') / 4.0
    
    # Wall adjacency
    wall_adj_b = 0
    wall_adj_w = 0
    # Expand impassable by 1 in all directions
    imp_exp = impassable_bb
    for d in dirs:
        imp_exp |= (impassable_bb << d) # This might go out of bounds, but we mask later
    # Better to check per piece
    for p in range(64):
        if (black_bb >> p) & 1:
            for d in dirs:
                sq = p + d
                r, c = divmod(sq, 8)
                if 0 <= r <= 7 and 0 <= c <= 7:
                    if (impassable_bb >> sq) & 1:
                        wall_adj_b += 1
                        break
        if (white_bb >> p) & 1:
            for d in dirs:
                sq = p + d
                r, c = divmod(sq, 8)
                if 0 <= r <= 7 and 0 <= c <= 7:
                    if (impassable_bb >> sq) & 1:
                        wall_adj_w += 1
                        break
                        
    wall_adj_b /= 4.0
    wall_adj_w /= 4.0
    
    # Assemble features
    feats = [
        mob_b / 64.0, mob_w / 64.0,
        excl_b_cnt / 64.0, excl_w_cnt / 64.0, contested_cnt / 64.0,
        trapped_b / 4.0, trapped_w / 4.0,
        fill,
        float(turn),
        sym,
        center_b, center_w,
        corner_b, corner_w,
        edge_b, edge_w,
        wall_adj_b, wall_adj_w,
        (mob_b - mob_w) / 64.0, # diff normalized
        (excl_b_cnt - excl_w_cnt) / 64.0,
        (trapped_b - trapped_w) / 4.0,
        (center_b - center_w),
        (corner_b - corner_w),
        (edge_b - edge_w),
        (wall_adj_b - wall_adj_w),
        mob_b / (mob_b + mob_w + 1.0),
        excl_b_cnt / (excl_b_cnt + excl_w_cnt + 1.0),
        (mob_b + excl_b_cnt) / 128.0, # Black advantage proxy
        (mob_w + excl_w_cnt) / 128.0, # White advantage proxy
    ]
    
    # Pad or trim to 32
    while len(feats) < MAPPED_DIM:
        feats.append(0.0)
    feats = feats[:MAPPED_DIM]
    
    return torch.tensor(feats, dtype=torch.float32)
