import torch

MAPPED_DIM = 32
DESCRIPTION = "Mobility, reach, space, turn, center/corner/edge control, ratios & diffs"

def mapping(board_tensor: torch.Tensor) -> torch.Tensor:
    black = board_tensor[:64].bool()
    white = board_tensor[64:128].bool()
    impassable = board_tensor[128:192].bool()
    turn = board_tensor[192].long()
    
    free = ~black & ~white & ~impassable
    
    dirs = [-8, 8, -1, 1, -9, -7, 7, 9]
    orth = [-8, 8, -1, 1]
    
    def count_mob(pieces, fb):
        t = 0
        for p in torch.nonzero(pieces, as_tuple=True)[0]:
            p = p.item()
            for d in dirs:
                c = p + d
                while 0 <= c < 64:
                    if d in (-1,1) and c//8 != p//8: break
                    if d in (-9,-7,7,9):
                        if abs(c//8 - p//8) != abs(c%8 - p%8): break
                    if not fb[c]: break
                    t += 1
                    c += d
        return t

    def count_reach(pieces, fb):
        vis = torch.zeros(64, dtype=torch.bool)
        q = torch.nonzero(pieces, as_tuple=True)[0].tolist()
        for x in q: vis[x] = True
        h = 0
        while h < len(q):
            c = q[h]; h += 1
            for d in dirs:
                n = c + d
                if 0 <= n < 64:
                    if d in (-1,1) and n//8 != c//8: continue
                    if d in (-9,-7,7,9):
                        if abs(n//8 - c//8) != abs(n%8 - c%8): continue
                    if fb[n] and not vis[n]:
                        vis[n] = True; q.append(n)
        return vis.sum().item()

    def count_adj(pieces, fb):
        t = 0
        for p in torch.nonzero(pieces, as_tuple=True)[0]:
            p = p.item()
            for d in orth:
                n = p + d
                if 0 <= n < 64 and d in (-1,1) and n//8 != p//8: continue
                if fb[n]: t += 1
        return t

    def count_on_mask(pieces, mask):
        return (pieces & mask).sum().item()

    center_mask = torch.zeros(64, dtype=torch.bool)
    center_mask[20:44] = True
    corner_mask = torch.zeros(64, dtype=torch.bool)
    corner_mask[[0,7,56,63]] = True
    edge_mask = torch.zeros(64, dtype=torch.bool)
    edge_mask[:8] = True
    edge_mask[56:] = True
    edge_mask[::8] = True
    edge_mask[7::8] = True
    edge_mask &= ~corner_mask

    mb = count_mob(black, free)
    wb = count_mob(white, free)
    rb = count_reach(black, free)
    rw = count_reach(white, free)
    ab = count_adj(black, free)
    aw = count_adj(white, free)
    ib = impassable.sum().item()
    tb = turn.item()
    cb = count_on_mask(black, center_mask)
    cw = count_on_mask(white, center_mask)
    cob = count_on_mask(black, corner_mask)
    cow = count_on_mask(white, corner_mask)
    eb = count_on_mask(black, edge_mask)
    ew = count_on_mask(white, edge_mask)
    fr = free.sum().item()

    f = []
    f.append(mb / 60.0)
    f.append(wb / 60.0)
    f.append(rb / 64.0)
    f.append(rw / 64.0)
    f.append(ib / 64.0)
    f.append(tb)
    f.append(cb / 4.0)
    f.append(cw / 4.0)
    f.append(cob / 4.0)
    f.append(cow / 4.0)
    f.append(eb / 8.0)
    f.append(ew / 8.0)
    f.append(ab / 16.0)
    f.append(aw / 16.0)
    f.append(fr / 64.0)
    
    s = mb + wb + 1
    f.append(mb / s)
    f.append(wb / s)
    s = rb + rw + 1
    f.append(rb / s)
    f.append(rw / s)
    s = ab + aw + 1
    f.append(ab / s)
    f.append(aw / s)
    
    f.append((mb - wb + 60) / 120.0)
    f.append((rb - rw + 64) / 128.0)
    f.append((ab - aw + 16) / 32.0)
    f.append((cb - cw + 4) / 8.0)
    f.append((cob - cow + 4) / 8.0)
    f.append((eb - ew + 8) / 16.0)
    f.append(fr / 64.0)
    f.append(tb)
    f.append(ib / 64.0)
    f.append(cb / 4.0)
    f.append(cw / 4.0)
    
    while len(f) < MAPPED_DIM:
        f.append(0.0)
    f = f[:MAPPED_DIM]
    
    return torch.tensor(f, dtype=torch.float32)
