            for d in dirs:
                sq = p + d
                nr, nc = divmod(sq, 8)
                if 0 <= nr <= 7 and 0 <= nc <= 7:
                    if (impassable_bb >> sq) & 1:
                        wall_adj_b += 1
                        break
        if (white_bb >> p) & 1:
            for d in dirs:
