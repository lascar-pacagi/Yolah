                    if occ[sq] or imp[sq]:
                        break
                    mob += 1
                    nr += dr
                    nc += dc
        return mob

    def get_reachable_mask(pieces, occ, imp):
        free = ~occ & ~imp
        reachable = np.zeros(64, dtype=bool)
        for p in pieces:
            if free[p]:
                reachable[p] = True
        changed = True
        while changed:
            changed = False
            for p in np.where(reachable)[0]:
                r, c = divmod(p, 8)
                for dr, dc in dirs:
                    nr, nc = r + dr, c + dc
                    while 0 <= nr < 8 and 0 <= nc < 8:
                        sq = nr * 8 + nc
                        if free[sq] and not reachable[sq]:
                            reachable[sq] = True
                            changed = True
                        if occ[sq] or imp[sq]:
                            break
                        nr += dr
                        nc += dc
        return reachable

    def imp_in_line(pieces, target_mask):
        count = 0
        for p in pieces:
            r, c = divmod(p, 8)
            for dr, dc in dirs:
                nr, nc = r + dr, c + dc
                while 0 <= nr < 8 and 0 <= nc < 8:
                    sq = nr * 8 + nc
                    if target_mask[sq]:
                        count += 1
                    if black[sq] or white[sq] or impassable[sq]:
                        break
                    nr += dr
                    nc += dc
        return count

    def imp_adjacent(pieces, imp):
        count = 0
        for p in pieces:
            r, c = divmod(p, 8)
            for dr in [-1, 0, 1]:
                for dc in [-1, 0, 1]:
                    if dr == 0 and dc == 0: continue
                    nr, nc = r + dr, c + dc
                    if 0 <= nr < 8 and 0 <= nc < 8:
                        if imp[nr * 8 + nc]:
                            count += 1
        return count

    b_mob = count_mobility(black_sq, white, impassable)
    w_mob = count_mobility(white_sq, black, impassable)
    
    b_mask = get_reachable_mask(black_sq, white, impassable)
    w_mask = get_reachable_mask(white_sq, black, impassable)
    
    b_space = np.sum(b_mask)
    w_space = np.sum(w_mask)
    
    center_mask = np.zeros(64, dtype=bool)
    for r in range(2, 6):
        for c in range(2, 6):
            center_mask[r * 8 + c] = True
    edge_mask = np.zeros(64, dtype=bool)
    for r in range(8):
        for c in range(8):
            if r == 0 or r == 7 or c == 0 or c == 7:
                edge_mask[r * 8 + c] = True
                
    b_center = np.sum(b_mask & center_mask)
    w_center = np.sum(w_mask & center_mask)
    b_edge = np.sum(b_mask & edge_mask)
    w_edge = np.sum(w_mask & edge_mask)
    
    def quadrant_counts(pieces):
        counts = np.zeros(4, dtype=float)
        for p in pieces:
            r, c = divmod(p, 8)
            q = (0 if r < 4 else 2) + (0 if c < 4 else 1)
            counts[q] += 1.0
        return counts
        
    b_quad = quadrant_counts(black_sq)
    w_quad = quadrant_counts(white_sq)
    
    b_imp_adj = imp_adjacent(black_sq, impassable)
    w_imp_adj = imp_adjacent(white_sq, impassable)
    
    free_total = np.sum(~black & ~white & ~impassable)
    total_moves = np.sum(impassable)
    
    def max_reach_one_piece(pieces, occ, imp):
        max_r = 0
        for p in pieces:
            mask = get_reachable_mask([p], occ, imp)
            cnt = np.sum(mask)
            if cnt > max_r:
                max_r = cnt
        return max_r
        
    def min_reach_one_piece(pieces, occ, imp):
        min_r = 64
        for p in pieces:
            mask = get_reachable_mask([p], occ, imp)
            cnt = np.sum(mask)
            if cnt < min_r:
                min_r = cnt
        return min_r
        
    b_max_r = max_reach_one_piece(black_sq, white, impassable)
    w_max_r = max_reach_one_piece(white_sq, black, impassable)
    b_min_r = min_reach_one_piece(black_sq, white, impassable)
    w_min_r = min_reach_one_piece(white_sq, black, impassable)
    
    b_dark = np.sum(black & (np.arange(64) % 2 == 1))
    w_dark = np.sum(white & (np.arange(64) % 2 == 1))
    b_light = 4.0 - b_dark
    w_light = 4.0 - w_dark
    
    b_center_pieces = np.sum(black & center_mask)
    w_center_pieces = np.sum(white & center_mask)
    b_edge_pieces = np.sum(black & edge_mask)
    w_edge_pieces = np.sum(white & edge_mask)
    
    b_imp_line = imp_in_line(black_sq, impassable)
    w_imp_line = imp_in_line(white_sq, impassable)
    
    free_mask = ~black & ~white & ~impassable
    b_free_line = imp_in_line(black_sq, free_mask)
    w_free_line = imp_in_line(white_sq, free_mask)
    
    feats = []
    feats.append(turn)
    feats.append(total_moves / 64.0)
    feats.append(b_mob / 128.0)
    feats.append(w_mob / 128.0)
    feats.append(b_space / 64.0)
    feats.append(w_space / 64.0)
    feats.append(b_center / 16.0)
    feats.append(w_center / 16.0)
    feats.append(b_edge / 28.0)
    feats.append(w_edge / 28.0)
    feats.extend(b_quad / 4.0)
    feats.extend(w_quad / 4.0)
    feats.append(b_imp_adj / 32.0)
    feats.append(w_imp_adj / 32.0)
    feats.append(free_total / 64.0)
    feats.append(b_max_r / 64.0)
    feats.append(w_max_r / 64.0)
    feats.append(b_min_r / 64.0)
    feats.append(w_min_r / 64.0)
    feats.append(b_dark / 4.0)
    feats.append(w_dark / 4.0)
    feats.append(b_center_pieces / 4.0)
    feats.append(w_center_pieces / 4.0)
    feats.append(b_edge_pieces / 4.0)
    feats.append(w_edge_pieces / 4.0)
    feats.append(b_imp_line / 128.0)
    feats.append(w_imp_line / 128.0)
    feats.append(b_free_line / 128.0)
    feats.append(w_free_line / 128.0)
    feats.append(b_mob / (4.0 * 128.0))
    feats.append(w_mob / (4.0 * 128.0))
    feats.append(b_space / (4.0 * 64.0))
    feats.append(w_space / (4.0 * 64.0))
    feats.append(b_imp_adj / (4.0 * 32.0))
    
    return torch.tensor(feats, dtype=torch.float32)
