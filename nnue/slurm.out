MAPPED_DIM = 32
DESCRIPTION = "Exclusive/contested mobility, trapped, symmetry, wall-adj, center/corner/edge control"

def mapping(board_tensor: torch.Tensor) -> torch.Tensor:
    bb = 0
    for i in range(193):
