                comp_size = 0
                while stack:
                    cr, cc = stack.pop()
                    if visited[cr, cc]: continue
                    visited[cr, cc] = True
                    comp_size += 1
                    for dr, dc in [(-1,0),(1,0),(0,-1),(0,1)]:
