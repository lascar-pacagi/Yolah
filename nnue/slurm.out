            if not has:
                trapped_b += 1
                
    trapped_w = 0
    for p in range(64):
        if (white_bb >> p) & 1:
            has = False
            for d in dirs:
                sq = p
                while True:
                    sq += d
                    nr, nc = divmod(sq, 8)
