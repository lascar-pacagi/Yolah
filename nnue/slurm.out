    imp_count = impassable.sum()
    feats.extend([free_count / 64.0, imp_count / 64.0])
    
    b_pos = np.argwhere(black)
    w_pos = np.argwhere(white)
    b_pos = np.pad(b_pos, ((0, 4 - len(b_pos)), (0, 0)), constant_values=7)
    w_pos = np.pad(w_pos, ((0, 4 - len(w_pos)), (0, 0)), constant_values=7)
    feats.extend((b_pos / 7.0).flatten().tolist())
    feats.extend((w_pos / 7.0).flatten().tolist())
    
    b_mobs = [piece_mobility(r, c) / 64.0 for r in range(8) for c in range(8) if black[r, c]]
    w_mobs = [piece_mobility(r, c) / 64.0 for r in range(8) for c in range(8) if white[r, c]]
    b_mobs.extend([0.0] * (4 - len(b_mobs)))
    w_mobs.extend([0.0] * (4 - len(w_mobs)))
    feats.extend(b_mobs)
    feats.extend(w_mobs)
    
    q1 = free[:4, :4].sum()
    q2 = free[:4, 4:].sum()
    q3 = free[4:, :4].sum()
    q4 = free[4:, 4:].sum()
    feats.extend([q1/16.0, q2/16.0, q3/16.0, q4/16.0])
    
    b_stuck = sum(1 for r in range(8) for c in range(8) if black[r,c] and piece_mobility(r,c)==0)
    w_stuck = sum(1 for r in range(8) for c in range(8) if white[r,c] and piece_mobility(r,c)==0)
    feats.extend([b_stuck/4.0, w_stuck/4.0])
    
    center = free[2:6, 2:6].sum()
    edge = free[0,:].sum() + free[7,:].sum() + free[:,0].sum() + free[:,7].sum()
    feats.extend([center/16.0, edge/28.0])
    
    visited = np.zeros((8,8), dtype=bool)
    max_comp = 0
    for r in range(8):
        for c in range(8):
            if free[r,c] and not visited[r,c]:
