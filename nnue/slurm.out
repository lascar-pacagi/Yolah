import torch

MAPPED_DIM = 32
DESCRIPTION = "Exclusive/contested mobility, trapped, symmetry, wall-adj, center/corner/edge control"

def mapping(board_tensor: torch.Tensor) -> torch.Tensor:
    bb = 0
    for i in range(193):
        if board_tensor[i].item() > 0.5:
            bb |= (1 << i)
            
    black_bb = bb & 0xFFFFFFFFFFFFFFFF
    white_bb = (bb >> 64) & 0xFFFFFFFFFFFFFFFF
    impassable_bb = (bb >> 128) & 0xFFFFFFFFFFFFFFFF
    turn = 1 if (bb >> 192) & 1 else 0
    
    dirs = [1, 8, -1, -8, 7, -7, 9, -9]  # E, S, W, N, SW, NE, SE, NW
    
    def get_mobility(pieces_bb):
        mob = 0
        tmp = pieces_bb
        while tmp:
            p = (tmp & -tmp).bit_length() - 1
            for d in dirs:
                sq = p
                while True:
                    sq += d
                    nr, nc = divmod(sq, 8)
                    if not (0 <= nr <= 7 and 0 <= nc <= 7):
                        break
                    # Prevent diagonal wrapping across board edges
                    if d == 7 and nc == 0: break
                    if d == -7 and nc == 7: break
                    if d == 9 and nc == 0: break
                    if d == -9 and nc == 7: break
                    if (impassable_bb >> sq) & 1:
                        break
                    if (black_bb >> sq) & 1 or (white_bb >> sq) & 1:
                        break
                    mob |= (1 << sq)
            tmp &= tmp - 1
        return mob

    black_mob = get_mobility(black_bb)
    white_mob = get_mobility(white_bb)
    
    excl_b = black_mob & (~white_mob & 0xFFFFFFFFFFFFFFFF)
    excl_w = white_mob & (~black_mob & 0xFFFFFFFFFFFFFFFF)
    contested = black_mob & white_mob
    
    mob_b = bin(black_mob).count('1')
    mob_w = bin(white_mob).count('1')
    excl_b_cnt = bin(excl_b).count('1')
    excl_w_cnt = bin(excl_w).count('1')
    contested_cnt = bin(contested).count('1')
    
    trapped_b = 0
    for p in range(64):
        if (black_bb >> p) & 1:
            has = False
            for d in dirs:
                sq = p
                while True:
                    sq += d
                    nr, nc = divmod(sq, 8)
                    if not (0 <= nr <= 7 and 0 <= nc <= 7): break
                    if d == 7 and nc == 0: break
                    if d == -7 and nc == 7: break
                    if d == 9 and nc == 0: break
                    if d == -9 and nc == 7: break
                    if (impassable_bb >> sq) & 1: break
                    if (black_bb >> sq) & 1 or (white_bb >> sq) & 1: break
                    has = True
                    break
                if has: break
            if not has:
                trapped_b += 1
                
    trapped_w = 0
    for p in range(64):
        if (white_bb >> p) & 1:
            has = False
            for d in dirs:
                sq = p
                while True:
                    sq += d
                    nr, nc = divmod(sq, 8)
                    if not (0 <= nr <= 7 and 0 <= nc <= 7): break
                    if d == 7 and nc == 0: break
                    if d == -7 and nc == 7: break
                    if d == 9 and nc == 0: break
                    if d == -9 and nc == 7: break
                    if (impassable_bb >> sq) & 1: break
                    if (black_bb >> sq) & 1 or (white_bb >> sq) & 1: break
                    has = True
                    break
                if has: break
            if not has:
                trapped_w += 1
                
    fill = bin(impassable_bb).count('1') / 64.0
    
    def rot180(bb):
        res = 0
        for i in range(64):
            if (bb >> i) & 1:
                res |= (1 << (63 - i))
        return res
    sym = 1.0 if (black_bb == rot180(white_bb) and white_bb == rot180(black_bb)) else 0.0
    
    center_mask = sum(1 << (r*8+c) for r in range(2,6) for c in range(2,6))
    corner_mask = 1 | (1<<7) | (1<<56) | (1<<63)
    edge_mask = 0
    for r in range(8):
        for c in range(8):
            if c==0 or c==7 or r==0 or r==7:
                edge_mask |= (1 << (r*8+c))
    edge_mask &= ~corner_mask
    
    center_b = bin(black_bb & center_mask).count('1') / 4.0
    center_w = bin(white_bb & center_mask).count('1') / 4.0
    corner_b = bin(black_bb & corner_mask).count('1') / 4.0
    corner_w = bin(white_bb & corner_mask).count('1') / 4.0
    edge_b = bin(black_bb & edge_mask).count('1') / 4.0
    edge_w = bin(white_bb & edge_mask).count('1') / 4.0
    
    wall_adj_b = 0
    wall_adj_w = 0
    for p in range(64):
        if (black_bb >> p) & 1:
            for d in dirs:
                sq = p + d
                nr, nc = divmod(sq, 8)
                if 0 <= nr <= 7 and 0 <= nc <= 7:
                    if d == 7 and nc == 0: continue
                    if d == -7 and nc == 7: continue
                    if d == 9 and nc == 0: continue
                    if d == -9 and nc == 7: continue
                    if (impassable_bb >> sq) & 1:
                        wall_adj_b += 1
                        break
        if (white_bb >> p) & 1:
            for d in dirs:
                sq = p + d
                nr, nc = divmod(sq, 8)
                if 0 <= nr <= 7 and 0 <= nc <= 7:
                    if d == 7 and nc == 0: continue
                    if d == -7 and nc == 7: continue
                    if d == 9 and nc == 0: continue
                    if d == -9 and nc == 7: continue
                    if (impassable_bb >> sq) & 1:
                        wall_adj_w += 1
                        break
    wall_adj_b /= 4.0
    wall_adj_w /= 4.0
    
    feats = [
        mob_b/64.0, mob_w/64.0, excl_b_cnt/64.0, excl_w_cnt/64.0, contested_cnt/64.0,
        trapped_b/4.0, trapped_w/4.0, fill, float(turn), sym,
        center_b, center_w, corner_b, corner_w, edge_b, edge_w, wall_adj_b, wall_adj_w,
        (mob_b-mob_w)/64.0, (excl_b_cnt-excl_w_cnt)/64.0, (trapped_b-trapped_w)/4.0,
        (center_b-center_w), (corner_b-corner_w), (edge_b-edge_w), (wall_adj_b-wall_adj_w),
        mob_b/(mob_b+mob_w+1.0), excl_b_cnt/(excl_b_cnt+excl_w_cnt+1.0),
        (mob_b+excl_b_cnt)/128.0, (mob_w+excl_w_cnt)/128.0,
        mob_b*mob_w/64.0, fill*turn, fill*(1.0-turn)
    ]
    
    return torch.tensor(feats, dtype=torch.float32)
<<<MAPPING_CODE_END>>>
