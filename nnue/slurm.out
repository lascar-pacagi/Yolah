    mob_w = bin(white_mob).count('1')
    excl_b_cnt = bin(excl_b).count('1')
    excl_w_cnt = bin(excl_w).count('1')
    contested_cnt = bin(contested).count('1')
    
    trapped_b = 0
    for p in range(64):
        if (black_bb >> p) & 1:
            has = False
            for d in dirs:
                sq = p
                while True:
                    sq += d
                    nr, nc = divmod(sq, 8)
                    if not (0 <= nr <= 7 and 0 <= nc <= 7): break
                    if d == 7 and nc == 0: break
                    if d == -7 and nc == 7: break
                    if d == 9 and nc == 0: break
                    if d == -9 and nc == 7: break
                    if (impassable_bb >> sq) & 1: break
                    if (black_bb >> sq) & 1 or (white_bb >> sq) & 1: break
                    has = True
                    break
