                max_comp = max(max_comp, comp_size)
    feats.append(max_comp / 64.0)
    
    feats.append(0.5 if turn == 1 else 0.0)
    
    while len(feats) < MAPPED_DIM:
        feats.append(0.0)
        
    return torch.tensor(feats[:MAPPED_DIM], dtype=torch.float32)
