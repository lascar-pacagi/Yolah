    f.append(mb / 60.0)
    f.append(wb / 60.0)
    f.append(rb / 64.0)
    f.append(rw / 64.0)
    f.append(ib / 64.0)
    f.append(tb)
    f.append(cb / 4.0)
    f.append(cw / 4.0)
    f.append(cob / 4.0)
    f.append(cow / 4.0)
    f.append(eb / 8.0)
