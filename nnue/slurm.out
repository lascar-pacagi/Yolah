```python
import torch
import numpy as np

MAPPED_DIM = 64
DESCRIPTION = "Mobility, reachability, space control, impassable count, turn, center control"

def mapping(board_tensor: torch.Tensor) -> torch.Tensor:
    black = board_tensor[:64].bool()
    white = board_tensor[64:128].bool()
    impassable = board_tensor[128:192].bool()
    turn = board_tensor[192].long()
    
    free = ~black & ~white & ~impassable
    
    # Directions for sliding
    dirs = [-8, 8, -1, 1, -9, -7, 7, 9]
    # Edge masks to prevent wrapping
    # Instead of complex masks, just check bounds in loop
    
    def count_mobility(pieces, free_board):
        total = 0
        indices = torch.nonzero(pieces, as_tuple=True)[0]
        for p in indices:
            p = p.item()
            for d in dirs:
                curr = p + d
                while 0 <= curr < 64:
                    # Check row/col wrap for horizontal moves
                    if d in (-1, 1) and (curr // 8 != (p + d) // 8): break
                    if d in (-9, -7, 7, 9):
                        r1, c1 = p // 8, p % 8
                        r2, c2 = curr // 8, curr % 8
                        if abs(r2 - r1) != abs(c2 - c1): break
                    if not free_board[curr]: break
                    total += 1
                    curr += d
        return total
    
    mob_b = count_mobility(black, free)
    mob_w = count_mobility(white, free)
    
    # Flood fill reachability
    def count_reach(pieces, free_board):
        visited = torch.zeros(64, dtype=torch.bool)
        queue = torch.nonzero(pieces, as_tuple=True)[0].tolist()
        for q in queue:
            visited[q] = True
        head = 0
        while head < len(queue):
            curr = queue[head]
            head += 1
            # Check 8 directions for free adjacent squares
            for d in dirs:
                nxt = curr + d
                if 0 <= nxt < 64:
                    if d in (-1, 1) and (nxt // 8 != curr // 8): continue
                    if d in (-9, -7, 7, 9):
                        r1, c1 = curr // 8, curr % 8
                        r2, c2 = nxt // 8, nxt % 8
                        if abs(r2 - r1) != abs(c2 - c1): continue
                    if free_board[nxt] and not visited[nxt]:
                        visited[nxt] = True
                        queue.append(nxt)
        return visited.sum().item()
        
    reach_b = count_reach(black, free)
    reach_w = count_reach(white, free)
    
    impassable_count = impassable.sum().item()
    turn_val = turn.item()
    
    # Center control (squares 20-43)
    center_mask = torch.zeros(64, dtype=torch.bool)
    center_mask[20:44] = True
    center_b = black[center_mask].sum().item()
    center_w = white[center_mask].sum().item()
    
    # Adjacent free squares (orthogonal)
    orth_dirs = [-8, 8, -1, 1]
    def count_adj_free(pieces, free_board):
        cnt = 0
        for p in torch.nonzero(pieces, as_tuple=True)[0]:
            p = p.item()
            for d in orth_dirs:
                nxt = p + d
                if 0 <= nxt < 64:
                    if d in (-1, 1) and (nxt // 8 != p // 8): continue
                    if free_board[nxt]:
                        cnt += 1
        return cnt
        
    adj_b = count_adj_free(black, free)
    adj_w = count_adj_free(white, free)
    
    # Normalize features to [0, 1]
    # Mobility max ~ 60, reach max ~ 64, impassable max 64, center max 4, adj max 16
    features = torch.tensor([
        mob_b / 60.0,
        mob_w / 60.0,
        reach_b / 64.0,
        reach_w / 64.0,
        impassable_count / 64.0,
        turn_val,
        center_b / 4.0,
        center_w / 4.0,
        adj_b / 16.0,
        adj_w / 16.0,
        (mob_b - mob_w) / 60.0, # mobility diff
        (reach_b - reach_w) / 64.0, # reach diff
        (adj_b - adj_w) / 16.0, # adj diff
    ], dtype=torch.float32)
    
    # Pad or truncate to MAPPED_DIM
    if features.shape[0] < MAPPED_DIM:
        features = torch.cat([features, torch.zeros(MAPPED_DIM - features.shape[0])])
    else:
        features = features[:MAPPED_DIM]
        
    return features
```

