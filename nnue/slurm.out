    white = bb_white.numpy().reshape(8, 8)
    impassable = bb_impassable.numpy().reshape(8, 8)
    free = ~black & ~white & ~impassable
    
    feats = []
    
    feats.append(turn)
    
    def piece_mobility(r, c):
